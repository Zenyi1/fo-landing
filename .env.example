# resend api key — get from https://resend.com/api-keys
RESEND_API_KEY=

# optional — defaults to onboarding@resend.dev (works without domain verification)
# once first-ocean.com is verified in resend, set to: "firstocean <noreply@first-ocean.com>"
CONTACT_FROM=

# anthropic api key for /originators valuation — get from https://platform.claude.com
# without it the funnel falls back to a deterministic heuristic
ANTHROPIC_API_KEY=
